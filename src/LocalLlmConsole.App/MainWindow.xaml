<Window x:Class="LocalLlmConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="llama.cpp Console v1.1" MinWidth="1180" MinHeight="760" Width="1280" Height="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource AppBack}"
        Loaded="Window_Loaded" Closing="Window_Closing">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        ResizeBorderThickness="7"
                        GlassFrameThickness="0"
                        CornerRadius="8"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>
  <Border Background="{DynamicResource AppBack}"
          CornerRadius="8"
          SnapsToDevicePixels="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="34"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Background="{DynamicResource AppBack}" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
      <Grid Margin="12,0,6,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="llama.cpp Console"
                     Foreground="{DynamicResource TextMuted}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <TextBlock x:Name="AppVersionText"
                     Text="v1.1"
                     Foreground="{DynamicResource TextMuted}"
                     FontSize="11"
                     Margin="8,0,0,0"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
          <Button x:Name="MinimizeButton" Style="{StaticResource TitleBarButton}" Content="-" Click="MinimizeButton_Click"/>
          <Button x:Name="MaximizeButton" Style="{StaticResource TitleBarButton}" Content="[ ]" Click="MaximizeButton_Click"/>
          <Button x:Name="CloseButton" Style="{StaticResource TitleBarButton}" Content="X" Click="CloseButton_Click"/>
        </StackPanel>
      </Grid>
      </Border>
      <Grid Grid.Row="1" Margin="18,0,18,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="232"/>
        <ColumnDefinition Width="18"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="18">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0">
            <Button x:Name="OverviewNavButton" Style="{StaticResource NavButton}" Content="Overview" Click="ShowOverview_Click"/>
            <Button x:Name="ModelsNavButton" Style="{StaticResource NavButton}" Content="Models" Click="ShowModels_Click"/>
            <Button x:Name="RuntimesNavButton" Style="{StaticResource NavButton}" Content="Runtimes" Click="ShowRuntimes_Click"/>
            <Button x:Name="SettingsNavButton" Style="{StaticResource NavButton}" Content="Settings" Click="ShowSettings_Click"/>
            <Button x:Name="OpenCodeNavButton" Style="{StaticResource NavButton}" Content="OpenCode" Click="ShowOpenCode_Click"/>
            <Button x:Name="LifetimeNavButton" Style="{StaticResource NavButton}" Content="Lifetime" Click="ShowLifetime_Click"/>
            <Button x:Name="LogsNavButton" Style="{StaticResource NavButton}" Content="Logs" Click="ShowLogs_Click"/>
            <Border Height="1"
                    Background="{DynamicResource PanelBorder}"
                    Margin="0,8,0,10"/>
            <TextBlock x:Name="ToolsNavLabel"
                       Text="Tools"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="12,0,0,8"/>
            <Button x:Name="WindowsNavButton" Style="{StaticResource NavButton}" Content="Windows" Click="ShowWindows_Click"/>
            <Button x:Name="WslLinuxNavButton" Style="{StaticResource NavButton}" Content="WSL Linux" Click="ShowWslLinux_Click"/>
          </StackPanel>
          <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <Border Background="{DynamicResource InputBack}"
                    BorderBrush="{DynamicResource PanelBorderStrong}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,0,10">
              <StackPanel>
                <TextBlock Text="Current action"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="AppStatusText"
                           Text="Starting..."
                           Foreground="{DynamicResource TextSoft}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
            <Button x:Name="UpdatesNavButton" Style="{StaticResource NavButton}" Content="Check For Updates" Click="ShowUpdates_Click"/>
            <Button x:Name="HelpNavButton" Style="{StaticResource NavButton}" Content="Help" Click="ShowHelp_Click"/>
          </StackPanel>
        </Grid>
      </Border>
      <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border Style="{StaticResource Panel}" Padding="0">
        <ContentControl x:Name="PageHost"/>
      </Border>
      </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
